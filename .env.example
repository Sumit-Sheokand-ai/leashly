# ── Database ───────────────────────────────────────────────────
# SQLite (default). For production use an absolute path or volume mount:
DATABASE_URL="file:./data/prod.db"

# ── NextAuth ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_32_CHAR_RANDOM_SECRET"
# Your public app URL — no trailing slash
NEXTAUTH_URL="https://yourdomain.com"

# ── Encryption ────────────────────────────────────────────────
# MUST be exactly 32 characters — used for AES-256 key encryption
# Generate: openssl rand -hex 16
ENCRYPTION_KEY="REPLACE_WITH_EXACTLY_32_CHAR_KEY"
