generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String   @id
  email                String   @unique
  plan                 String   @default("free")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())

  // Leashly upgrade fields
  billingModel        String  @default("flat")
  cacheEnabled        Boolean @default(true)
  routingEnabled      Boolean @default(false)
  cacheTtlHours       Int     @default(24)
  similarityThreshold Float   @default(0.97)

  apiKeys              ApiKey[]
  rules                Rule[]
  requestLogs          RequestLog[]
  alerts               Alert[]
  notifications        Notification[]
  routingRules         RoutingRule[]
  cacheEntries         CacheEntry[]
  benchmarkJobs        BenchmarkJob[]
  workspaceMemberships WorkspaceMember[]
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  keyHash      String
  encryptedKey String
  proxyKey     String   @unique
  provider     String
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]
}

model Rule {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  config    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RequestLog {
  id               String   @id @default(cuid())
  userId           String
  apiKeyId         String
  timestamp        DateTime @default(now())
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalCost        Float    @default(0)
  flagged          Boolean  @default(false)
  flagReason       String?
  durationMs       Int      @default(0)
  statusCode       Int      @default(200)

  // Leashly upgrade — savings tracking
  wasRouted            Boolean @default(false)
  originalModel        String?
  actualModel          String?
  routingSavings       Float   @default(0)
  wasCacheHit          Boolean @default(false)
  cacheSavings         Float   @default(0)
  wasCompressed        Boolean @default(false)
  originalPromptTokens Int?
  compressedTokens     Int?
  compressionSavings   Float   @default(0)
  totalSavings         Float   @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  type        String
  threshold   Float
  notifyEmail String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoutingRule {
  id          String   @id @default(cuid())
  userId      String
  name        String
  condition   Json     @default("{}")
  targetModel String
  provider    String
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CacheEntry {
  id         String   @id @default(cuid())
  userId     String
  model      String
  promptHash String
  // embedding managed via raw Supabase RPC (pgvector)
  response   Json
  tokens     Int      @default(0)
  cost       Float    @default(0)
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
  expiresAt  DateTime @default(dbgenerated("now() + interval '24 hours'"))
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([promptHash])
}

model BenchmarkJob {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("pending")
  providers   String[]  @default([])
  testType    String    @default("short_factual")
  results     Json?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Workspace {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  plan          String            @default("free")
  monthlyBudget Float?
  createdAt     DateTime          @default(now())
  members       WorkspaceMember[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("developer")
  joinedAt    DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}
